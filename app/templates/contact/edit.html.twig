{% extends 'base.html.twig' %}

{% block title %}Edit {{ contact.name }} {{ contact.surname }}{% endblock %}

{% block body %}
    <h1>Edit {{ contact.name }} {{ contact.surname }}</h1>

    {{ form_start(form, {action: path('app_contact_edit', {slug: contact.slug, back: backUrl})}) }}
        {% for field in form %}
            {% if field.vars.name != '_token' %}
                <div>
                    {{ form_label(field) }}
                    {{ form_widget(field) }}
                    {{ form_errors(field) }}
                </div>
            {% endif %}
        {% endfor %}
        <button type="submit">Save</button>
    {{ form_end(form) }}

    <form action="{{ path('app_contact_delete', {slug: contact.slug}) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this contact?')">
        <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ contact.id) }}">
        <button type="submit">Delete</button>
    </form>

    <a href="{{ backUrl }}">Back to list</a>
{% endblock %}
